# ============== F.R.E.S.H Backend ==============

# Server
PORT=3000
NODE_ENV=development

# Database (Supabase Postgres — Transaction pooler URI)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# CORS — Vercel/Netlify frontend URL (or http://localhost:5173 for dev).
# Boleh multiple, dipisah koma. Atau pakai "*" sementara saat frontend belum siap.
CORS_ORIGIN=http://localhost:5173

# JWT — dipakai untuk session token aplikasi (login email/password)
JWT_SECRET=replace-with-a-long-random-string

# Email (Resend API — https://resend.com)
# Daftar di resend.com, buat API key, verifikasi domain.
# Untuk testing tanpa domain: pakai EMAIL_FROM=onboarding@resend.dev
# (hanya bisa kirim ke email akun Resend kamu sendiri)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=FRESH App <noreply@yourdomain.com>
OTP_EXPIRED_MINUTES=5

# Supabase API (Google Sign-In token verification + Storage).
# Backend tetap jalan kalau ini kosong, hanya Google login yang dimatikan.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=uploads

# AI Service (FastAPI). Backend will fall back to deterministic heuristics
# if these endpoints are unreachable, so the app keeps working.
AI_PREDICT_RISK_URL=http://localhost:8000/predict-risk
AI_SCAN_URL=http://localhost:8000/scan
AI_RECOMMENDATION_URL=http://localhost:8000/recommend
